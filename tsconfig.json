{
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": { "@/*": ["./src/*"] },
    "target": "ES2022",
    "types": ["bun", "node"]
  },
  "include": ["src"]
}
